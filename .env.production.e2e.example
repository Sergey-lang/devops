# Конфиг для прогона e2e против развернутого инстанса на твоём VPS.
#
# Шаги:
#   1) Скопируй этот файл: cp .env.production.e2e.example .env.production.e2e
#   2) Подставь свой реальный домен в E2E_BASE_URL и E2E_API_URL
#   3) make e2e-deployed

E2E_BASE_URL=https://your-domain.example
E2E_API_URL=https://your-domain.example/api
